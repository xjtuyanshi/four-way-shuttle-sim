{
  "name": "four-way-shuttle-sim",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "typecheck": "corepack pnpm -r --if-present typecheck",
    "test": "vitest run apps/shuttle-api apps/shuttle-dashboard && vitest run packages/shuttle-sim-core",
    "test:watch": "vitest",
    "dev:api": "corepack pnpm --filter shuttle-api dev",
    "dev:dashboard": "corepack pnpm --filter shuttle-dashboard dev",
    "preview:dashboard": "corepack pnpm --filter shuttle-dashboard preview --host 0.0.0.0",
    "shuttle:prereq": "corepack pnpm --filter shuttle-api prereq",
    "shuttle:validate": "corepack pnpm --filter shuttle-api validate:phase0",
    "shuttle:validate:report": "corepack pnpm --filter shuttle-api validate:phase0 ../../output/shuttle/phase0-validation-report.json",
    "shuttle:ws-smoke": "node scripts/smoke-shuttle-ws.mjs",
    "test:shuttle": "vitest run packages/shuttle-sim-core",
    "unreal:setup": "node scripts/setup-unreal-visual-twin.mjs",
    "unreal:build": "node scripts/smoke-unreal-visual-twin.mjs --build-only",
    "unreal:smoke": "node scripts/smoke-unreal-visual-twin.mjs",
    "unreal:stage": "node scripts/stage-unreal-visual-twin.mjs",
    "unreal:pixelstreaming:check": "node scripts/check-pixel-streaming-readiness.mjs",
    "build": "corepack pnpm run typecheck && corepack pnpm --filter shuttle-dashboard build"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
